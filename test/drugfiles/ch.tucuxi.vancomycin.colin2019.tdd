                        </activeMoieties>
                        <analyteGroups>
                            <analyteGroup>
                                <groupId>vancomycin</groupId>
                                <pkModelId>linear.2comp.macro</pkModelId>
                                <analytes>
                                    <analyte>
                                        <analyteId>vancomycin</analyteId>
                                        <unit>mg/l</unit>
                                        <molarMass>
                                            <value>1449.3</value>
                                            <unit>g/mol</unit>
                                        </molarMass>
                                        <description>
                                            <desc lang='en'>
                                            </desc>
                                        </description>
                                        <errorModel>
                                            <errorModelType>mixed</errorModelType>
                                            <sigmas>
                                                <sigma>
                                                    <standardValue>1.23</standardValue>
                                                </sigma>
                                                <sigma>
                                                    <standardValue>0.215</standardValue>
                                                </sigma>
                                            </sigmas>
                                            <comments>
                                            </comments>
                                        </errorModel>
                                        <comments/>
                                    </analyte>
                                </analytes>
                                <dispositionParameters>
                                    <parameters>
                                        <parameter>
                                            <parameterId>CL</parameterId>
                                            <unit>l/h</unit>
                                            <parameterValue>
                                                <standardValue>5.31</standardValue>
                                                <aprioriComputation>
                                                    <softFormula>
                                                        <inputs>
                                                            <input>
                                                                <id>bodyweight</id>
                                                                <type>double</type>
                                                            </input>
                                                            <input>
                                                                <id>ga</id>
                                                                <type>double</type>
                                                            </input>
                                                            <input>
                                                                <id>pna</id>
                                                                <type>double</type>
                                                            </input>
                                                            <input>
                                                                <id>scr</id>
                                                                <type>double</type>
                                                            </input>
                                                            <input>
                                                                <id>haem</id>
                                                                <type>double</type>
                                                            </input>
                                                        </inputs>
                                                        <code>
                                                            <![CDATA[
                                                            theta_CL = 5.31;
                                                            theta_v1 = 42.9;
                                                            gamma1 = 2.89;
                                                            gamma2 = 2.24;
                                                            PMA50 = 46.4;
                                                            AGE50 = 61.6;
                                                            theta_scr = 0.649;
                                                            theta_stdy10 = 0.294;
                                                            theta_v1 = 42.9;


                                                            F_size = bodyweight / 70.0;
                                                            v1 = theta_v1 * F_size;
                                                            scr = scr/88.4;

                                                            PMA_wk = ga + pna / 7.0;
                                                            PMA_yr = (ga * 7.0 + pna) / 365.0;
                                                            SCR_std = Math.exp(-1.228 + Math.log10(PMA_yr)*0.672+6.27*Math.exp(-3.11*PMA_yr));
                                                            F_scr = Math.exp(-theta_scr*(scr-SCR_std));
                                                            F_mat = Math.pow(PMA_wk, gamma1)/(Math.pow(PMA_wk, gamma1) + Math.pow(PMA50, gamma1));
                                                            F_decline = Math.pow(PMA_yr, -gamma2)/(Math.pow(PMA_yr,-gamma2) + Math.pow(AGE50,-gamma2));

                                                            newCL = theta_CL * Math.pow(v1/theta_v1, 0.75) * F_mat * F_decline * F_scr * (1 + theta_stdy10 * haem);

                                                            return newCL;
                                                            ]]>
                                                        </code>
                                                    </softFormula>
                                                    <comments>
                                                        <comment lang='en'>F decline formula is wrong in the paper. should be F_decline = Math.pow(PMA_yr, -gamma2) / (Math.pow(PMA_yr, -gamma2) + Math.pow(AGE50, -gamma2));
                                                                                                                                                                                                                                                                                                    (sub PMA_yr = 61.6 into the formula - should be 0.5 by definition).

                                                                                                                                                                                                                                                                                Also I don&apos;t understand the theta_stdy13_v1 parameter (and the other ones like it). It looks like there should be an indicator function here, which =1 if heelprick sampling is used and 0 if it is not. But they haven&apos;t written it like this. Heel prick sampling is not done in practice, so we can ignre this, but I think we need to have &apos;haematology patient&apos; as a boolean/logical variable. I have coded it double (like sex has been coded).   </comment>
                                                    </comments>
                                                </aprioriComputation>
                                            </parameterValue>
                                            <bsv>
                                                <bsvType>lognormal</bsvType>
                                                <stdDevs>
                                                    <stdDev>0.07495997</stdDev>
                                                </stdDevs>
                                            </bsv>
                                            <comments>
                                                <comment lang='en'>Paper states these were lognormally distributed</comment>
                                            </comments>
                                        </parameter>
                                        <parameter>
                                            <parameterId>V1</parameterId>
                                            <unit>l</unit>
                                            <parameterValue>
                                                <standardValue>42.9</standardValue>
                                                <aprioriComputation>
                                                    <softFormula>
                                                        <inputs>
                                                            <input>
                                                                <id>bodyweight</id>
                                                                <type>double</type>
                                                            </input>
                                                        </inputs>
                                                        <code>
                                                            <![CDATA[
                                                            theta_v1 = 42.9;

                                                            F_size = bodyweight / 70.0;
                                                            newV1 = theta_v1 * F_size;
                                                            return newV1;
                                                            ]]>
                                                        </code>
                                                    </softFormula>
                                                    <comments/>
                                                </aprioriComputation>
                                            </parameterValue>
                                            <bsv>
                                                <bsvType>lognormal</bsvType>
                                                <stdDevs>
                                                    <stdDev>0.07188243</stdDev>
                                                </stdDevs>
                                            </bsv>
                                            <comments>
                                                <comment lang='en'>Typical volume calculated for a patients with weight = 70kg (table 3).</comment>
                                            </comments>
                                        </parameter>
                                        <parameter>
                                            <parameterId>V2</parameterId>
                                            <unit>l</unit>
                                            <parameterValue>
                                                <standardValue>41.7</standardValue>
                                                <aprioriComputation>
                                                    <softFormula>
                                                        <inputs>
                                                            <input>
                                                                <id>bodyweight</id>
                                                                <type>double</type>
                                                            </input>
                                                        </inputs>
                                                        <code>
                                                            <![CDATA[theta_v2 = 41.7;

                                                            TVV2 = theta_v2 * bodyweight / 70.0;
                                                            return TVV2;
                                                            ]]>
                                                        </code>
                                                    </softFormula>
                                                    <comments/>
                                                </aprioriComputation>
                                            </parameterValue>
                                            <bsv>
                                                <bsvType>lognormal</bsvType>
                                                <stdDevs>
                                                    <stdDev>0.6721487</stdDev>
                                                </stdDevs>
                                            </bsv>
                                            <comments>
                                                <comment lang='en'>Typical volume calculated for a patients with weight = 70 kg</comment>
                                            </comments>
                                        </parameter>
                                        <parameter>
                                            <parameterId>Q</parameterId>
                                            <unit>l/h</unit>
                                            <parameterValue>
                                                <standardValue>3.22</standardValue>
                                                <aprioriComputation>
                                                    <softFormula>
                                                        <inputs>
                                                            <input>
                                                                <id>bodyweight</id>
                                                                <type>double</type>
                                                            </input>
                                                        </inputs>
                                                        <code>
                                                            <![CDATA[
                                                            theta_v2 = 41.7;
                                                            TVV2 = theta_v2 * bodyweight / 70.0;
                                                            theta_q2 = 3.22;
                                                            TQ = theta_q2 * Math.pow(TVV2/theta_v2, 0.75);

                                                            return TQ;
                                                            ]]>
                                                        </code>
                                                    </softFormula>
                                                    <comments/>
                                                </aprioriComputation>
                                            </parameterValue>

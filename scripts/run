#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd -- "${SCRIPT_DIR}/.." && pwd)"

# shellcheck source=/dev/null
source "$SCRIPT_DIR/common/common.sh"
# shellcheck source=/dev/null
source "$SCRIPT_DIR/common/cmake.sh"
# shellcheck source=/dev/null
source "$SCRIPT_DIR/common/python.sh"

cmd="${1:-help}"
shift || true
parse_global_opts "$@"

dispatch() {
  case "$cmd" in
    help|-h|--help) usage ;;
    build)          source "$SCRIPT_DIR/commands/build.sh" ;;
    build-gtest)    source "$SCRIPT_DIR/commands/gtest.sh"; cmd_build_gtest "$@" ;;
    run-gtest)      source "$SCRIPT_DIR/commands/gtest.sh"; cmd_run_gtest "$@" ;;
    py-env)         source "$SCRIPT_DIR/commands/python_deps.sh"; cmd_py_env "$@" ;;
    py-deps)        source "$SCRIPT_DIR/commands/python_deps.sh"; cmd_py_deps "$@" ;;
    fuzz)           source "$SCRIPT_DIR/commands/fuzz.sh"; cmd_fuzz "$@" ;;
    imatinib)       source "$SCRIPT_DIR/commands/imatinib.sh"; cmd_imatinib "$@" ;;
    cb-driver)      source "$SCRIPT_DIR/commands/cb_driver.sh"; cmd_cb_driver "$@" ;;
    coverage)       source "$SCRIPT_DIR/commands/coverage.sh"; cmd_coverage "$@" ;;
    format)         source "$SCRIPT_DIR/commands/format.sh" ;;
    tidy)           source "$SCRIPT_DIR/commands/tidy.sh" ;;
    clean)          source "$SCRIPT_DIR/commands/clean.sh" ;;
    *) die "Unknown command: $cmd" 2 ;;
  esac
}

dispatch "$@"